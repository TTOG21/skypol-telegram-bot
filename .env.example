# Telegram Bot Token from @BotFather
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# LLM configuration
# Provider: anthropic or openai (Kimi, OpenRouter, etc.)
# Kimi coding uses an Anthropic-compatible endpoint
LLM_PROVIDER=anthropic
LLM_API_KEY=your_api_key_here

# Base URL for OpenAI-compatible APIs
# Kimi/Moonshot: https://api.moonshot.cn/v1
# OpenRouter: https://openrouter.ai/api/v1
LLM_BASE_URL=https://api.kimi.com/coding/

# Model name
# Kimi examples: kimi-k2-0711-preview, moonshot-v1-8k
# Anthropic examples: claude-3-haiku-20240307, claude-3-5-sonnet-20241022
LLM_MODEL=kimi-k2-0711-preview

# Timeout in seconds for a single LLM API call (default: 30)
LLM_TIMEOUT=30

# Number of retries on transient LLM API failures (default: 1)
LLM_MAX_RETRIES=1

# LLM response cache: avoid repeated API calls for identical questions (default: 300s / 1000 entries)
LLM_CACHE_TTL_SECONDS=300
LLM_CACHE_MAX_ENTRIES=1000

# Render external URL (e.g. https://skypol-bot.onrender.com)
RENDER_EXTERNAL_URL=

# Optional: Admin chat ID(s) for human escalation notifications.
# Supports a single ID or multiple comma-separated IDs, e.g. 123456789,987654321
ADMIN_CHAT_ID=

# Optional: Webhook secret token for extra security
WEBHOOK_SECRET=

# Optional: Rate limiting for the /webhook endpoint (default: 10 requests per second)
WEBHOOK_RATE_LIMIT_RPS=10
WEBHOOK_RATE_LIMIT_WINDOW=1

# Max conversation history messages per user
MAX_HISTORY=10

# Optional: Persist conversation memory to a JSON file (default: false)
PERSIST_MEMORY=false
MEMORY_FILE_PATH=.memory.json

# Group flood protection thresholds
FLOOD_MAX_MESSAGES=5
FLOOD_WINDOW_SECONDS=10
FLOOD_MUTE_SECONDS=60

# Logging configuration (text or json)
LOG_LEVEL=INFO
LOG_FORMAT=text

# Optional: log to a file with rotation (default: console only)
# LOG_FILE=logs/bot.log
LOG_FILE_MAX_BYTES=10485760
LOG_FILE_BACKUPS=5
